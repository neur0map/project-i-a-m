{
    "label" : "lock",
    "action" : "swaylock -f --screenshots --effect-blur 20x5 --effect-vignette 0.5:0.5 --ring-color a63d4f --key-hl-color c45c6e --inside-color 0e0e0ecc --line-color 1c1c1c --text-color d4d0ce --separator-color 1c1c1c",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "niri msg action quit",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
