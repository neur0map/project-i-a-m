#!/usr/bin/env bash
#
# iam — Project I.A.M dotfile manager
#
# Two modes of operation:
#   Maintainer (push access) — full control: update, save, track, override
#   User (no push access)    — consume updates: update, override
#
# Access is determined by `gh api` checking push permissions on the remote.
# Users authenticate with `gh auth login` before first use.
#
set -euo pipefail

# ── Config ────────────────────────────────────────────────────────
#
# Auto-detect repo root by following this script's symlink back.
# scripts/.local/bin/iam → ../../.. → repo root
#
if [[ -z "${IAM_DIR:-}" ]]; then
    _self="$(readlink -f "$0")"
    IAM_DIR="$(cd "$(dirname "$_self")/../../.." && pwd)"
    unset _self
fi

STOW_PACKAGES=(rice shell security scripts)
PACKAGES_DIR="$IAM_DIR/packages"
REMOTE_URL="origin"
BRANCH="main"
DIST_FILE="$IAM_DIR/.iamdist"

# Derived at runtime — no hardcoded usernames
GH_USER=""
REPO_SLUG=""
REPO_OWNER=""

RED="#a63d4f"
DIM="#666666"
TEXT="#d4d0ce"
BG="#0e0e0e"

# ── Output ───────────────────────────────────────────────────────
#
# Styled terminal output using gum.
#
die()  { gum style --foreground "$RED" "  $*"; exit 1; }
info() { gum style --foreground "$TEXT" "  $*"; }
dim()  { gum style --foreground "$DIM" "  $*"; }
ok()   { gum style --foreground 2 "  $*"; }

# ── Dependency checks ────────────────────────────────────────────
#
# Verify required commands are available before proceeding.
#
need() {
    for cmd in "$@"; do
        command -v "$cmd" &>/dev/null || die "$cmd not found. Install it first."
    done
}

# ── Authentication & access ──────────────────────────────────────
#
# gh auth is optional. Without it, users can still pull updates
# from public repos. gh is only required for push access (save,
# track) and enables richer identity/role detection.
#

gh_is_authed() {
    command -v gh &>/dev/null && gh auth status &>/dev/null
}

require_gh_auth() {
    # Hard gate — used by save/track which cannot work without auth.
    if ! command -v gh &>/dev/null; then
        die "GitHub CLI (gh) not found. Install with: sudo pacman -S github-cli"
    fi
    if ! gh auth status &>/dev/null; then
        info "GitHub authentication required for this action."
        echo
        dim "Run: gh auth login"
        echo
        gum confirm "Open gh auth login now?" && {
            gh auth login
        } || die "Authentication required. Run 'gh auth login' and try again."
        gh auth status &>/dev/null || die "Authentication failed. Try again."
        ok "Authenticated with GitHub"
        echo
    fi
    detect_identity
}

try_gh_auth() {
    # Soft gate — try to detect identity if gh is available,
    # but don't block if it's not. Used by update/status/menu.
    detect_repo_slug
    if gh_is_authed; then
        detect_identity
    fi
}

detect_repo_slug() {
    # Extract owner/repo from the git remote URL. Works without gh.
    [[ -n "$REPO_SLUG" ]] && return

    local remote_url
    remote_url=$(git -C "$IAM_DIR" remote get-url "$REMOTE_URL" 2>/dev/null || echo "")

    if [[ -n "$remote_url" ]]; then
        REPO_SLUG=$(echo "$remote_url" | sed -E 's#.*github\.com[:/]##; s/\.git$//')
        REPO_OWNER="${REPO_SLUG%%/*}"
    fi
}

detect_identity() {
    # Resolve the GitHub username via gh api. Requires auth.
    [[ -n "$GH_USER" ]] && return
    detect_repo_slug
    GH_USER=$(gh api user --jq '.login' 2>/dev/null || echo "")
}

has_push_access() {
    # Check if the authenticated user has push permissions on the remote.
    # Returns false if gh is not authed (safe default).
    [[ -z "$REPO_SLUG" ]] && return 1
    gh_is_authed || return 1

    local permission
    permission=$(gh api "repos/$REPO_SLUG" --jq '.permissions.push' 2>/dev/null || echo "false")
    [[ "$permission" == "true" ]]
}

is_upstream() {
    # Check if the remote points to the original (upstream) repo.
    # Without gh auth, falls back to assuming upstream (safe default).
    [[ -z "$REPO_SLUG" ]] && return 0

    if gh_is_authed; then
        local parent
        parent=$(gh api "repos/$REPO_SLUG" --jq '.parent.full_name // empty' 2>/dev/null || echo "")
        [[ -z "$parent" ]]
    else
        # Can't check — assume upstream (restricts to user menu, safe default)
        return 0
    fi
}

# ── UI ───────────────────────────────────────────────────────────

header() {
    clear
    gum style \
        --border double \
        --border-foreground "$RED" \
        --padding "1 3" \
        --align center \
        --width 40 \
        "P R O J E C T" "" "I . A . M"
    echo

    # Show account and role info
    if [[ -n "$GH_USER" ]]; then
        local role="user"
        if has_push_access 2>/dev/null; then
            if is_upstream 2>/dev/null; then
                role="maintainer"
            else
                role="fork owner"
            fi
        fi
        dim "  @${GH_USER}  ·  ${role}  ·  ${REPO_SLUG:-local}"
    elif [[ -n "$REPO_SLUG" ]]; then
        dim "  not signed in  ·  ${REPO_SLUG}"
    fi
    echo
}

# ── Distribution ─────────────────────────────────────────────────
#
# .iamdist controls what configs ship to users vs what stays
# maintainer-only. Everything is tracked in git (syncs between
# maintainer machines), but users only receive what's listed.
#
# Format:
#   rice            — include this stow package
#   !rice/.config/x — exclude this path from distribution
#

# Parse .iamdist: return stow packages to distribute
dist_packages() {
    [[ -f "$DIST_FILE" ]] || { echo "${STOW_PACKAGES[@]}"; return; }
    grep -v '^#' "$DIST_FILE" | grep -v '^!' | grep -v '^$'
}

# Parse .iamdist: return exclude patterns (lines starting with !)
dist_excludes() {
    [[ -f "$DIST_FILE" ]] || return
    grep '^!' "$DIST_FILE" | sed 's/^!//'
}

# Check if a repo-relative path matches any exclude pattern
is_excluded() {
    local file="$1"
    local pattern
    while IFS= read -r pattern; do
        [[ -z "$pattern" ]] && continue
        # shellcheck disable=SC2254
        if [[ "$file" == $pattern ]]; then
            return 0
        fi
    done < <(dist_excludes)
    return 1
}

# ── Stow strategies ─────────────────────────────────────────────
#
# stow_all  — maintainer: symlink everything, no filtering
# stow_dist — user: symlink only distributed configs, preserve
#              user overrides (real files that aren't symlinks)
#

stow_all() {
    cd "$IAM_DIR"
    for pkg in "${STOW_PACKAGES[@]}"; do
        [[ -d "$pkg" ]] || continue
        stow --restow --target="$HOME" "$pkg" 2>/dev/null || true
    done
}

stow_dist() {
    cd "$IAM_DIR"
    local pkg

    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        [[ -d "$pkg" ]] || continue

        # Step 1: Back up user overrides (real files where stow wants symlinks).
        #         A real file means the user ran 'iam override' or manually
        #         replaced the symlink — we must not clobber it.
        local tmpdir
        tmpdir=$(mktemp -d)

        find "$pkg" -type f | while read -r repo_file; do
            local rel="${repo_file#"$pkg"/}"
            local home_file="$HOME/$rel"

            if [[ -f "$home_file" && ! -L "$home_file" ]]; then
                local save_path="$tmpdir/$rel"
                mkdir -p "$(dirname "$save_path")"
                cp -p "$home_file" "$save_path"
                rm "$home_file"
            fi
        done

        # Step 2: Stow the package (creates/updates symlinks)
        stow --restow --target="$HOME" "$pkg" 2>/dev/null || true

        # Step 3: Remove symlinks for excluded files (.iamdist ! patterns)
        find "$pkg" -type f | while read -r repo_file; do
            if is_excluded "$repo_file"; then
                local rel="${repo_file#"$pkg"/}"
                local home_file="$HOME/$rel"
                [[ -L "$home_file" ]] && rm "$home_file"
            fi
        done

        # Step 4: Restore user overrides (put real files back over symlinks)
        if [[ -d "$tmpdir" ]]; then
            find "$tmpdir" -type f 2>/dev/null | while read -r saved; do
                local rel="${saved#"$tmpdir"/}"
                local home_file="$HOME/$rel"
                rm -f "$home_file"
                mkdir -p "$(dirname "$home_file")"
                cp -p "$saved" "$home_file"
            done
        fi

        rm -rf "$tmpdir"
    done < <(dist_packages)
}

# ═════════════════════════════════════════════════════════════════
#  ACTIONS
# ═════════════════════════════════════════════════════════════════

# ── Update ───────────────────────────────────────────────────────
#
# Pull the latest changes from the remote, install any new or
# missing packages, and apply configs.
#
# Maintainer: uses pull --rebase to preserve local work.
# User: uses reset --hard for a clean sync to latest.
# User overrides (real files) are preserved across updates.
#
do_update() {
    need git stow
    try_gh_auth
    header

    gum spin --spinner dot --title "Checking for updates..." -- \
        git -C "$IAM_DIR" fetch "$REMOTE_URL" "$BRANCH" --quiet
    local behind
    behind=$(git -C "$IAM_DIR" rev-list --count HEAD.."$REMOTE_URL/$BRANCH" 2>/dev/null || echo 0)

    if [[ "$behind" -eq 0 ]]; then
        ok "Already up to date — you have the latest version"
    else
        info "$behind new update(s) available"
        echo
        dim "Changelog:"
        git -C "$IAM_DIR" log --oneline HEAD.."$REMOTE_URL/$BRANCH" | while read -r line; do
            dim "  $line"
        done
        echo
        gum confirm "Apply updates?" || { dim "Skipped."; return; }

        if has_push_access; then
            git -C "$IAM_DIR" pull --rebase "$REMOTE_URL" "$BRANCH"
        else
            git -C "$IAM_DIR" reset --hard "$REMOTE_URL/$BRANCH" --quiet
        fi
        ok "Updated to latest version"
    fi
    echo

    # Install missing packages
    local missing_pkgs=""
    local pkg_manager="yay"
    command -v yay &>/dev/null || pkg_manager="sudo pacman"

    dim "Checking packages..."
    for file in "$PACKAGES_DIR"/*.txt; do
        [[ -f "$file" ]] || continue
        while IFS= read -r pkg; do
            [[ -z "$pkg" || "$pkg" == \#* ]] && continue
            if ! pacman -Qi "$pkg" &>/dev/null; then
                missing_pkgs+="$pkg "
            fi
        done < "$file"
    done

    if [[ -n "$missing_pkgs" ]]; then
        local count
        count=$(echo "$missing_pkgs" | wc -w | tr -d ' ')
        info "Installing $count new package(s)..."
        echo
        # shellcheck disable=SC2086
        $pkg_manager -S --needed --noconfirm $missing_pkgs 2>&1 | \
            while IFS= read -r line; do
                dim "  $line"
            done
        echo
        ok "Packages installed"
    else
        ok "All packages installed"
    fi

    # Apply configs
    if has_push_access; then
        stow_all
    else
        stow_dist
    fi
    ok "Configs applied"

    # System configs (optional, requires sudo)
    if [[ -d "$IAM_DIR/system/etc" ]]; then
        gum confirm "Apply system configs (/etc)?" && {
            sudo cp -r "$IAM_DIR/system/etc/"* /etc/ 2>/dev/null || true
            ok "System configs deployed"
        }
    fi

    echo
    ok "Update complete. You're running the latest I.A.M."
}

# ── Save ─────────────────────────────────────────────────────────
#
# Snapshot installed packages, commit all changes, and push to
# the remote. Only available with push access (maintainer or
# fork owner).
#
do_save() {
    need git
    require_gh_auth
    header
    has_push_access || die "No push access to this remote. Fork the repo on GitHub, update your remote, and try again."

    info "Snapshotting installed packages..."
    mkdir -p "$PACKAGES_DIR"
    pacman -Qqen > "$PACKAGES_DIR/native-packages.txt"
    pacman -Qqem > "$PACKAGES_DIR/aur-packages.txt"

    cd "$IAM_DIR"

    local changes
    changes=$(git status --porcelain)
    if [[ -z "$changes" ]]; then
        ok "Nothing to save. Already up to date."
        return
    fi

    # ── Show changes ─────────────────────────────────────────────
    echo
    dim "Changes detected:"
    echo
    git -C "$IAM_DIR" status --short | while read -r line; do
        dim "  $line"
    done
    echo

    # ── Distribution filter ──────────────────────────────────────
    # Only show for upstream maintainer — fork owners ship everything
    # in their fork, so dist filtering doesn't apply to them.

    if is_upstream; then
        # Collect changed config files (inside stow packages only,
        # skip iam internals that change on every save)
        local config_files=()
        while IFS= read -r file; do
            # Skip iam internals
            case "$file" in
                scripts/.local/bin/iam) continue ;;
                .iamdist)               continue ;;
                packages/native-packages.txt) continue ;;
                packages/aur-packages.txt)    continue ;;
            esac
            for pkg in "${STOW_PACKAGES[@]}"; do
                if [[ "$file" == "$pkg/"* ]]; then
                    config_files+=("$file")
                    break
                fi
            done
        done < <(git -C "$IAM_DIR" status --porcelain | awk '{print $NF}')

        if [[ ${#config_files[@]} -gt 0 ]]; then
            dim "Which files should be EXCLUDED from users?"
            dim "  Space = toggle, Enter = confirm"
            echo

            # Build comma-separated list of already-excluded files
            local preselected=""
            for f in "${config_files[@]}"; do
                if is_excluded "$f"; then
                    [[ -n "$preselected" ]] && preselected+=","
                    preselected+="$f"
                fi
            done

            # fzf multi-select with live diff preview
            # Navigate with ↑↓, Tab to toggle, Enter to confirm, Esc to ship all
            # Preview pane shows the git diff for the highlighted file
            need fzf

            # Build input: mark already-excluded files so user sees current state
            local fzf_input=""
            for f in "${config_files[@]}"; do
                if is_excluded "$f"; then
                    fzf_input+="[excluded] $f"$'\n'
                else
                    fzf_input+="[ships]    $f"$'\n'
                fi
            done

            local excluded_raw=""
            set +e
            excluded_raw=$(printf '%s' "$fzf_input" | \
                fzf --multi \
                    --header "Tab = toggle · Enter = confirm · Esc = ship all
Selected files will be EXCLUDED from users (maintainer-only)
Ctrl-A = toggle all" \
                    --preview "echo {} | sed 's/^\[.*\] *//' | xargs git -C '$IAM_DIR' diff HEAD --" \
                    --preview-window "right:60%:wrap" \
                    --preview-label " diff " \
                    --prompt "exclude> " \
                    --color "fg:#d4d0ce,bg:#0e0e0e,hl:#a63d4f,fg+:#f0ecea,bg+:#1c1c1c,hl+:#c45c6e,pointer:#a63d4f,marker:#a63d4f,prompt:#a63d4f,header:#666666,border:#333333" \
                    --marker "✗ " \
                    --pointer "▸" \
                    --bind "ctrl-a:toggle-all" \
                    --border rounded \
                    --no-info \
                    2>/dev/null)
            set -e

            # Strip the [excluded]/[ships] prefix to get clean file paths
            local excluded_selection=""
            if [[ -n "$excluded_raw" ]]; then
                while IFS= read -r line; do
                    [[ -z "$line" ]] && continue
                    local clean
                    clean=$(echo "$line" | sed 's/^\[.*\] *//')
                    excluded_selection+="$clean"$'\n'
                    ok "  $clean → maintainer-only"
                done <<< "$excluded_raw"
            else
                dim "  All files will ship to users"
            fi
            echo

            # Rebuild .iamdist: keep excludes for files NOT in this changeset
            local kept_excludes=""
            while IFS= read -r pattern; do
                [[ -z "$pattern" ]] && continue
                local in_changeset=false
                for f in "${config_files[@]}"; do
                    # shellcheck disable=SC2254
                    if [[ "$f" == $pattern ]]; then
                        in_changeset=true
                        break
                    fi
                done
                if ! $in_changeset; then
                    kept_excludes+="!${pattern}"$'\n'
                fi
            done < <(dist_excludes)

            # Add newly selected excludes from the picker
            local new_excludes=""
            if [[ -n "$excluded_selection" ]]; then
                while IFS= read -r selected; do
                    [[ -z "$selected" ]] && continue
                    new_excludes+="!${selected}"$'\n'
                done <<< "$excluded_selection"
            fi

            # Write .iamdist cleanly
            local dist_pkgs
            dist_pkgs=$(grep -v '^#' "$DIST_FILE" | grep -v '^!' | grep -v '^$')
            local all_excludes="${kept_excludes}${new_excludes}"

            {
                cat <<'HEADER'
# .iamdist — managed by 'iam save'
# Packages below are distributed to users.
# Lines starting with ! are excluded (maintainer-only).
# Do not edit manually — use 'iam save' to toggle exclusions.

# Stow packages to distribute
HEADER
                echo "$dist_pkgs"

                if [[ -n "$all_excludes" ]]; then
                    echo ""
                    echo "# Maintainer-only (excluded from distribution)"
                    printf '%s' "$all_excludes"
                fi
            } > "${DIST_FILE}.tmp"
            mv "${DIST_FILE}.tmp" "$DIST_FILE"

            # Report
            local total_excluded
            total_excluded=$(grep -c '^!' "$DIST_FILE" 2>/dev/null || echo 0)
            echo
            if [[ "$total_excluded" -gt 0 ]]; then
                ok "$total_excluded file(s) excluded from distribution"
            else
                ok "All config files will ship to users"
            fi
            echo
        fi
    fi

    # ── Commit type ──────────────────────────────────────────────

    # Detect which areas were touched (ignore iam internals)
    local changed_areas=""
    local all_files
    all_files=$(git -C "$IAM_DIR" status --porcelain | awk '{print $NF}')

    # Check each area — || true prevents set -e from killing on no match
    echo "$all_files" | grep -q '^rice/'      && changed_areas+="rice "     || true
    echo "$all_files" | grep -q '^shell/'     && changed_areas+="shell "    || true
    echo "$all_files" | grep -q '^security/'  && changed_areas+="security " || true
    echo "$all_files" | grep -q '^system/'    && changed_areas+="system "   || true
    echo "$all_files" | grep -q 'README'      && changed_areas+="docs "     || true

    # Only count scripts/ if something other than iam itself changed
    echo "$all_files" | grep '^scripts/' | grep -qv 'scripts/\.local/bin/iam$' \
        && changed_areas+="scripts " || true
    # Only count packages/ if something other than snapshots changed
    echo "$all_files" | grep '^packages/' \
        | grep -qvE '(native-packages|aur-packages)\.txt$' \
        && changed_areas+="packages " || true

    # If only iam internals changed, label it as iam
    if [[ -z "$changed_areas" ]]; then
        changed_areas="iam"
    else
        changed_areas=$(echo "$changed_areas" | xargs | tr ' ' ', ')
    fi

    local commit_type
    commit_type=$(gum choose \
        --header "What kind of change is this?" \
        --cursor.foreground "$RED" \
        --header.foreground "$DIM" \
        "update" "fix" "add" "remove" "docs")
    [[ -z "$commit_type" ]] && return

    # ── Commit message ───────────────────────────────────────────

    # Auto-generate a summary from changed file names (strip paths, dedupe)
    local auto_summary=""
    auto_summary=$(git -C "$IAM_DIR" status --porcelain | awk '{print $NF}' \
        | grep -v '^\.' \
        | grep -v '^scripts/\.local/bin/iam$' \
        | grep -v '^packages/\(native-packages\|aur-packages\)\.txt$' \
        | sed 's|.*/||' \
        | sort -u \
        | paste -sd ', ' -)

    local prefix="${commit_type}(${changed_areas})"
    local default_msg="${prefix}: ${auto_summary}"

    dim "Auto-generated message (edit or press Enter to accept):"
    echo

    local msg
    msg=$(gum input \
        --placeholder "Describe what changed" \
        --value "$default_msg" \
        --width 80 \
        --char-limit 120)

    # If user cleared everything or just left the prefix with no description
    if [[ -z "$msg" || "$msg" == "${prefix}: " || "$msg" == "${prefix}:" ]]; then
        msg="${prefix}: ${auto_summary}"
    fi

    # ── Author ───────────────────────────────────────────────────

    local author_name author_email
    author_name=$(gh api user --jq '.name // .login' 2>/dev/null || echo "$GH_USER")
    author_email=$(gh api user --jq '.email // empty' 2>/dev/null || echo "")

    if [[ -z "$author_email" ]]; then
        local gh_id
        gh_id=$(gh api user --jq '.id' 2>/dev/null || echo "0")
        author_email="${gh_id}+${GH_USER}@users.noreply.github.com"
    fi

    # ── Commit & push ────────────────────────────────────────────

    gum confirm "Save and push?" || return

    git -C "$IAM_DIR" add -A

    gum spin --spinner dot --title "Saving..." -- \
        git -C "$IAM_DIR" commit \
            --author="$author_name <$author_email>" \
            -m "$msg"
    gum spin --spinner dot --title "Pushing..." -- \
        git -C "$IAM_DIR" push "$REMOTE_URL" "$BRANCH"

    echo
    ok "Saved and pushed."
    dim "  $msg"
}

# ── Track ────────────────────────────────────────────────────────
#
# Adopt an existing config file or directory into the repo.
# Moves the file into the chosen stow package and symlinks it
# back to its original location. Only available with push access.
#
do_add() {
    header
    need stow
    require_gh_auth
    has_push_access || die "No push access to this remote. Fork the repo on GitHub, update your remote, and try again."

    local target
    target=$(gum input --placeholder "Path to adopt (e.g. ~/.config/ghostty)")
    [[ -z "$target" ]] && die "No path given."

    target="${target/#\~/$HOME}"
    target="$(realpath "$target" 2>/dev/null || echo "$target")"

    [[ -e "$target" ]] || die "Path does not exist: $target"

    local rel_path="${target#$HOME/}"
    [[ "$rel_path" == "$target" ]] && die "Path must be under \$HOME"

    local stow_pkg
    stow_pkg=$(gum choose --header "Add to which group?" "${STOW_PACKAGES[@]}")
    [[ -z "$stow_pkg" ]] && die "No group selected."

    local dest="$IAM_DIR/$stow_pkg/$rel_path"
    local dest_dir
    dest_dir=$(dirname "$dest")

    mkdir -p "$dest_dir"

    if [[ -L "$target" ]]; then
        die "Already a symlink (maybe already tracked?): $target"
    fi

    mv "$target" "$dest"
    ok "Moved to $stow_pkg/$rel_path"

    cd "$IAM_DIR"
    stow --restow --target="$HOME" "$stow_pkg"
    ok "Symlinked back to $target"

    echo
    dim "Run 'iam' → Save to commit this change."
}

# ── Override ─────────────────────────────────────────────────────
#
# Detach a config file from iam management. Replaces the symlink
# with a real copy so the user can customize it freely. Future
# updates will skip this file. Available to all users.
#
# To revert: delete the file and run 'iam update' — the symlink
# will be recreated from the repo.
#
do_override() {
    try_gh_auth
    header

    local target
    target=$(gum input --placeholder "Config to customize (e.g. ~/.config/ghostty/config)")
    [[ -z "$target" ]] && die "No path given."

    target="${target/#\~/$HOME}"
    target="$(realpath -s "$target" 2>/dev/null || echo "$target")"

    if [[ -L "$target" ]]; then
        local real_source
        real_source="$(readlink -f "$target")"
        rm "$target"
        cp -p "$real_source" "$target"
        ok "Detached: $target"
        dim "This file is now yours. Future updates won't overwrite it."
        echo
        dim "To go back to managed: rm the file and run 'iam update'"
    elif [[ -f "$target" ]]; then
        ok "Already a local file — not managed by iam"
    else
        die "File not found: $target"
    fi
}

# ── Status ───────────────────────────────────────────────────────
#
# Show the current state: local changes, last save timestamp,
# and whether the remote is ahead or behind. Available to all.
#
do_status() {
    need git
    try_gh_auth
    header

    cd "$IAM_DIR"

    local changes
    changes=$(git status --porcelain)

    if [[ -z "$changes" ]]; then
        ok "Clean. No changes since last save."
    else
        dim "Changed files:"
        echo
        git status --short | while read -r line; do
            info "  $line"
        done
    fi

    echo

    local last
    last=$(git log -1 --format="%ar — %s" 2>/dev/null || echo "never")
    dim "Last save: $last"

    git fetch "$REMOTE_URL" "$BRANCH" --quiet 2>/dev/null || true
    local behind ahead
    behind=$(git rev-list --count HEAD.."$REMOTE_URL/$BRANCH" 2>/dev/null || echo 0)
    ahead=$(git rev-list --count "$REMOTE_URL/$BRANCH"..HEAD 2>/dev/null || echo 0)

    [[ "$behind" -gt 0 ]] && info "Remote is $behind commits ahead (run Update)"
    [[ "$ahead" -gt 0 ]] && info "Local is $ahead commits ahead (run Save)"
    [[ "$behind" -eq 0 && "$ahead" -eq 0 ]] && ok "In sync with remote"
}

# ═════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════

main() {
    need gum

    # ── CLI subcommands (for scripting / direct use) ─────────────
    case "${1:-}" in
        update)   do_update;   return ;;
        save)     do_save;     return ;;
        track)    do_add;      return ;;
        override) do_override; return ;;
        status)   do_status;   return ;;
        # Legacy aliases
        sync)     do_update;   return ;;
        add)      do_add;      return ;;
    esac

    # ── Interactive TUI menu ─────────────────────────────────────
    try_gh_auth
    header

    if has_push_access; then
        # ── Maintainer / fork owner menu ─────────────────────────
        local choice
        choice=$(gum choose \
            --header "What do you want to do?" \
            --cursor.foreground "$RED" \
            --header.foreground "$DIM" \
            "Update     Pull latest changes, install packages & apply configs" \
            "Save       Snapshot your system and push changes to your repo" \
            "Track      Start tracking a new config file or directory" \
            "Override   Detach a config file to customize it locally" \
            "Status     Show sync state, local changes & version info" \
            "Quit")

        case "$choice" in
            Update*)   do_update ;;
            Save*)     do_save ;;
            Track*)    do_add ;;
            Override*) do_override ;;
            Status*)   do_status ;;
            *)         exit 0 ;;
        esac
    else
        # ── User menu (read-only) ───────────────────────────────
        if is_upstream; then
            dim "Read-only — fork on GitHub to save your own changes"
            echo
        fi

        local choice
        choice=$(gum choose \
            --header "What do you want to do?" \
            --cursor.foreground "$RED" \
            --header.foreground "$DIM" \
            "Update     Pull latest changes, install packages & apply configs" \
            "Override   Detach a config file to customize it locally" \
            "Status     Show current version and check for updates" \
            "Quit")

        case "$choice" in
            Update*)   do_update ;;
            Override*) do_override ;;
            Status*)   do_status ;;
            *)         exit 0 ;;
        esac
    fi
}

main "$@"
